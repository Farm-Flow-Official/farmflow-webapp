# Origin of the FarmFlow Elysia API (no /api/v1 suffix — generated paths include it).
# Local dev: the API runs on port 3000 (docker compose up api).
#
# DEPLOYMENT (Vercel): this file is git-ignored, so Vercel never sees it. You MUST
# set FARMFLOW_API_URL in Vercel → Settings → Environment Variables for ALL scopes
# (Production, Preview, Development) and redeploy — otherwise the API client throws
# "FARMFLOW_API_URL is not set" and login fails with "ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้".
# Staging API origin: https://api.18.136.12.211.nip.io
FARMFLOW_API_URL=http://localhost:3000
